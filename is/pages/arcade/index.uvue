  display: inline-flex;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  font-size: 22rpx;
  letter-spacing: 2rpx;
}

.hero-title {
  display: block;
  margin-top: 20rpx;
  font-size: 46rpx;
  font-weight: 700;
}

.hero-desc {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.7;
  opacity: 0.92;
}

.hero-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 28rpx;
}

.hero-primary-button,
.hero-secondary-button {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.hero-primary-button {
  background: #ffffff;
  color: #28324f;
}

.hero-secondary-button {
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.22);
  color: #ffffff;
}

.chip-card,
.section-card {
  margin-top: 22rpx;
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.section-link {
  flex-shrink: 0;
  padding-top: 6rpx;
  font-size: 24rpx;
  color: #5a6fff;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 22rpx;
}

.search-chip {
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  background: #eef0ff;
}

.search-chip-text {
  font-size: 24rpx;
  color: #4453d7;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 22rpx;
}

.product-card {
  padding: 18rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 30rpx rgba(32, 45, 73, 0.08);
}

.product-image {
  width: 100%;
  height: 240rpx;
  border-radius: 20rpx;
  background: #edf2fa;
}

.product-name {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.product-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #7b879a;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.product-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-top: 18rpx;
}


.product-more {
  font-size: 22rpx;
  color: #52627c;
}

.shortcut-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 22rpx;
}

.shortcut-card {
  padding: 26rpx 24rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 30rpx rgba(32, 45, 73, 0.06);
}

.accent-card {
  background: linear-gradient(135deg, #eff1ff 0%, #ffffff 100%);
}

.shortcut-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1c2535;
}

.shortcut-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #748198;
}

.empty-box {
  padding: 56rpx 24rpx;
  text-align: center;
  color: #94a3b8;
  font-size: 24rpx;
}

@media screen and (min-width: 960px) {
  .product-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
}

.theme-dark { background: #050505; }
.theme-dark .page-shell { background: #050505; }
</style>
