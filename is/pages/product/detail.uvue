  min-height: 100vh;
}

.detail-swiper-box {
  width: 100%;
  padding: 24rpx 24rpx 8rpx;
  box-sizing: border-box;
}

.detail-swiper {
  width: 100%;
  height: 460rpx;
}

.detail-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 10rpx;
  box-sizing: border-box;
  height: 100%;
  width: 100%;
}

.detail-cell-wrap {
  position: relative;
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
  overflow: hidden;
  background: #edf2fa;
  box-shadow: 0 8rpx 22rpx rgba(36, 53, 86, 0.12);
}

.detail-cell-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.detail-swiper-empty {
  margin: 24rpx;
  height: 460rpx;
  border-radius: 24rpx;
  background: #edf2fa;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-image {
  width: 100%;
  height: 100%;
}

.detail-swiper-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #eef3fb 0%, #dde7f7 100%);
}

.detail-swiper-placeholder {
  padding: 20rpx 28rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.82);
  font-size: 26rpx;
  color: #6e7d97;
}

.detail-container {
  margin-top: 24rpx;
  position: relative;
  z-index: 2;
}

.detail-hero-card {
  padding: 26rpx;
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 18rpx 48rpx rgba(25, 49, 91, 0.1);
}

.detail-hero-layout {
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  width: 100%;
}

.detail-identity {
  display: flex;
  flex-direction: column;
  flex: 0 0 220rpx;
  width: 220rpx;
  min-width: 220rpx;
}

.detail-avatar-wrap {
  width: 150rpx;
  height: 150rpx;
  margin: 0 auto;
  padding: 10rpx;
  border-radius: 34rpx;
  background: linear-gradient(145deg, #f5f8ff 0%, #e8eefb 100%);
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.72);
}

.detail-avatar,
.detail-avatar-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 26rpx;
}

.detail-avatar {
  background: #edf2fa;
}

.detail-avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #edf2fa;
  font-size: 24rpx;
  color: #7c879c;
}

.detail-hero-info {
  display: flex;
  flex-direction: column;
  flex: 1 1 auto;
  width: 0;
  min-width: 0;
}

.detail-name {
  display: block;
  margin-top: 18rpx;
  font-size: 42rpx;
  font-weight: 700;
  color: #16213a;
  line-height: 1.35;
  text-align: center;
}

.detail-en {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #7c879c;
  text-align: center;
}

.detail-tags {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx;
  margin-top: 4rpx;
}

