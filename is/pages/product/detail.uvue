}

.detail-info-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #f7f9fd;
}

.detail-info-label {
  flex-shrink: 0;
  font-size: 22rpx;
  color: #7d869b;
}

.detail-info-value {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  font-weight: 600;
  color: #203252;
  line-height: 1.5;
  text-align: right;
}

.detail-hero-foot {
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 24rpx;
  padding-top: 22rpx;
  border-top: 2rpx solid #edf2f8;
}

.detail-price-block {
  flex: 1;
  min-width: 0;
}

.detail-energy-inline {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #ff7b3f;
}

.detail-energy-block {
  flex-shrink: 0;
  min-width: 180rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: #fff4ea;
  text-align: center;
}

.detail-energy-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #ff7b3f;
}

.detail-energy-label {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #ad6c41;
}

.exchange-button {
  display: block;
  width: 100%;
  margin-top: 24rpx;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 22rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.exchanged-wrap {
  margin-top: 24rpx;
}

.exchanged-button {
  margin-top: 0 !important;
  background: linear-gradient(135deg, #16c17c 0%, #0f9d63 100%) !important;
  color: #ffffff !important;
}

.countdown-bar {
  margin-top: 16rpx;
  padding: 18rpx 24rpx;
  border-radius: 18rpx;
  background: rgba(255, 122, 68, 0.08);
  border: 2rpx solid rgba(255, 122, 68, 0.25);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

