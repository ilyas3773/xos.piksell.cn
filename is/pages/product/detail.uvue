<template>
  <view :class="themeClass">
    <scroll-view class="page-shell" scroll-y="true">
      <view class="detail-page" v-if="detail.id">
      <view class="detail-swiper-box" v-if="loopedImages().length > 0">
        <swiper
          class="detail-swiper"
          circular="true"
          indicator-dots="false"
          autoplay="true"
          interval="2500"
          duration="1200"
          :display-multiple-items="2"
          previous-margin="0rpx"
          next-margin="0rpx"
        >
          <swiper-item v-for="(item, idx) in loopedImages()" :key="'detail-img-' + idx">
            <view class="detail-cell">
              <view class="detail-cell-wrap">
                <image class="detail-cell-image" :src="cover(item)" mode="aspectFill"></image>
              </view>
            </view>
          </swiper-item>
        </swiper>
      </view>
      <view class="detail-swiper-empty" v-else>
        <view class="detail-swiper-placeholder">暂无轮播图</view>
      </view>

      <view class="page-container detail-container">
        <view class="detail-hero-card">
          <view class="detail-hero-layout">
            <view class="detail-identity">
              <view class="detail-avatar-wrap">
                <image v-if="detailIcon() != ''" class="detail-avatar" :src="cover(detailIcon())" mode="aspectFill"></image>
                <view v-else class="detail-avatar-placeholder">图标</view>
              </view>

              <text class="detail-name">{{ detail.name }}</text>
              <text class="detail-en">{{ detail.name_en || 'Digital Product' }}</text>
            </view>

            <view class="detail-hero-info">
              <view class="detail-tags">
                <text class="pill-tag" v-if="detail.category && detail.category.name">{{ detail.category.name }}</text>
                <text class="pill-tag warm-tag" v-if="detail.kindCategory && detail.kindCategory.name">{{ detail.kindCategory.name }}</text>
                <text class="pill-tag">{{ detail.compatibility || '兼容信息待补充' }}</text>
              </view>

              <view class="detail-info-list">
                <view class="detail-info-row">
                  <text class="detail-info-label">游戏大小</text>
                  <text class="detail-info-value">{{ detail.game_size || '未填写' }}</text>
                </view>
                <view class="detail-info-row">
                  <text class="detail-info-label">游戏语言</text>
                  <text class="detail-info-value">{{ detail.supported_languages || '未填写' }}</text>
                </view>
              </view>
            </view>
          </view>

          <!-- 兑换按钮 / 已兑换状态 -->
          <view v-if="activeOrderId > 0" class="exchanged-wrap">
            <button class="primary-button exchange-button exchanged-button" @click="goToActiveOrder">
              查看兑换内容
            </button>
            <view class="countdown-bar">
              <text class="countdown-label">兑换内容有效期剩余</text>
              <text class="countdown-time">{{ countdownText }}</text>
            </view>
          </view>
          <button v-else class="primary-button exchange-button" @click="showExchangeConfirm">
            使用 {{ detail.exchange_energy || 0 }} 能量立即兑换
          </button>
        </view>

        <view class="section-card" v-if="detail.description">
          <text class="section-title">游戏介绍</text>
          <text class="detail-description">{{ detail.description }}</text>
        </view>

        <view class="section-card" v-if="detail.recommend_products && detail.recommend_products.length > 0">
          <view class="title-row">
            <text class="section-title">相关推荐</text>
            <text class="section-link" @click="goAllProducts">查看更多</text>
          </view>
          <scroll-view class="recommend-scroll" scroll-x="true">
            <view class="recommend-row">
              <view class="recommend-card" v-for="item in detail.recommend_products" :key="'recommend-' + item.id" @click="goDetail(item.id)">
                <image class="recommend-image" :src="cover(item.display_image)" mode="aspectFill"></image>
                <text class="recommend-name">{{ item.name }}</text>
              </view>
            </view>
          </scroll-view>
        </view>

        <view class="safe-bottom-space"></view>
      </view>
    </view>

    <view class="empty-box" v-else>
      商品加载中...
    </view>

    <!-- 兑换确认弹窗 -->
    <view class="modal-overlay" v-if="showConfirmModal" @click="hideExchangeConfirm">
      <view class="modal-container" @click.stop>
        <view class="modal-header">
          <text class="modal-title">确认兑换</text>
        </view>
        <view class="modal-body">
          <text class="modal-message">确定兑换该资源吗？</text>
          <view class="modal-product-info">
            <image v-if="detailIcon() != ''" class="modal-product-image" :src="cover(detailIcon())" mode="aspectFill"></image>
            <view class="modal-product-details">
              <text class="modal-product-name">{{ detail.name }}</text>
            </view>
          </view>
        </view>
        <view class="modal-footer">
          <button class="modal-button cancel-button" @click="hideExchangeConfirm">取消</button>
          <button class="modal-button confirm-button" @click="confirmExchange">确定兑换</button>
        </view>
      </view>
    </view>
  </scroll-view>
  </view>
</template>

<script setup lang="uts">
import {
  getThemeMode,
  syncThemeChrome,
} from '../../utils/theme.uts'
import {
  copyText,
  checkActiveOrder,
  createOrder,
  externalUrl,
  fetchProduct,
  imageUrl,
  openProductDetail,
  openProductList,
} from '../../utils/shop.uts'
import {
  hasUserSession,
  openAuthPage,
} from '../../utils/user.uts'

const productId = ref(0)
const detailSwiperIndex = ref(0)
const detailSwiperHeight = ref(320)
const detailSwiperWidth = ref(0)
const detailImageRatios = ref<number[]>([])
const showConfirmModal = ref(false)
const activeOrderId = ref(0)
const activeOrderExpiresAt = ref('')
const countdownText = ref('00:00:00')
let countdownTimer: any = null
const detail = reactive({
  id: 0,
  name: '',
  name_en: '',
  exchange_energy: 0,
  description: '',
  game_size: '',
  supported_languages: '',
  compatibility: '',
  cover_image: '',
  images: [],
  category: null as any,
  kindCategory: null as any,
  resources: {
    downloads: [] as any[],
    tutorials: [] as any[],
  },
  recommend_products: [] as any[],
})

function systemWindowWidth(): number {
  const info = uni.getSystemInfoSync()
  const width = Number(info && info.windowWidth ? info.windowWidth : 0)
  if (width > 0) {
    return width
  }
  return 375
}

function clampSwiperHeight(height: number): number {
  if (height < 220) {
    return 220
  }
  if (height > 720) {
    return 720
  }
  return Math.round(height)
}

function syncSwiperHeightByRatio(ratio: number) {
  const safeRatio = Number(ratio || 0)
  if (safeRatio <= 0) {
    return
  }

  const width = detailSwiperWidth.value > 0 ? detailSwiperWidth.value : systemWindowWidth()
  detailSwiperHeight.value = clampSwiperHeight(width * safeRatio)
}

function resetDetailSwiperState() {
  detailSwiperIndex.value = 0
  detailSwiperWidth.value = systemWindowWidth()
  detailImageRatios.value = []
  detailSwiperHeight.value = clampSwiperHeight(detailSwiperWidth.value * 0.72)
}

function detailSwiperStyle(): string {
  return 'height:' + String(detailSwiperHeight.value) + 'px;'
}

// 循环图片：图片不足 6 张时复制几遍以保证循环顺畅
function loopedImages(): any[] {
  const list = detail.images
  if (!list || list.length == 0) {
    return []
  }
  if (list.length >= 6) {
    return list
  }
  const result: any[] = []
  while (result.length < 6) {
    for (let i = 0; i < list.length; i++) {
      result.push(list[i])
    }
  }
  return result
}

function cover(path: string): string {
  return imageUrl(path)
}

function detailIcon(): string {
  if (detail.cover_image != '') {
    return String(detail.cover_image || '')
  }

  if (detail.images && detail.images.length > 0) {
    return String(detail.images[0] || '')
  }

  return ''
}

function external(path: string): string {
  return externalUrl(path)
}

function onDetailImageLoad(index: number, event: any) {
  const width = event && event.detail && event.detail.width !== undefined
    ? Number(event.detail.width)
    : 0
  const height = event && event.detail && event.detail.height !== undefined
    ? Number(event.detail.height)
    : 0

  if (width <= 0 || height <= 0) {
    return
  }

  const ratio = height / width
  const nextRatios = detailImageRatios.value
  nextRatios[index] = ratio
  detailImageRatios.value = nextRatios

  if (index == detailSwiperIndex.value) {
    syncSwiperHeightByRatio(ratio)
  }
}

function onDetailSwiperChange(event: any) {
  const nextIndex = event && event.detail && event.detail.current !== undefined
    ? Number(event.detail.current)
    : 0
  detailSwiperIndex.value = nextIndex

  const ratios = detailImageRatios.value
  if (ratios && ratios.length > nextIndex) {
    const ratio = Number(ratios[nextIndex] || 0)
    if (ratio > 0) {
      syncSwiperHeightByRatio(ratio)
    }
  }
}

function copyLink(path: string) {
  copyText(externalUrl(path), '链接已复制')
}

function goAllProducts() {
  openProductList()
}

function goDetail(id: any) {
  openProductDetail(id)
}

function showExchangeConfirm() {
  // 已知有有效订单，直接跳转
  if (activeOrderId.value > 0) {
    uni.navigateTo({
      url: '/pages/order/result?id=' + encodeURIComponent(String(activeOrderId.value)),
    })
    return
  }

  // 未登录，先弹出登录提示再走兑换确认
  if (!hasUserSession()) {
    showConfirmModal.value = true
    return
  }

  // 已登录但 activeOrderId 还未加载完，实时检查一次
  uni.showLoading({
    title: '检查中...',
  })
  checkActiveOrder(productId.value).then((data) => {
    uni.hideLoading()
    if (data && data.has_active && data.order && data.order.id) {
      activeOrderId.value = Number(data.order.id)
      activeOrderExpiresAt.value = String(data.order.expires_at || '')
      startCountdown()
      uni.navigateTo({
        url: '/pages/order/result?id=' + encodeURIComponent(String(activeOrderId.value)),
      })
      return
    }
    showConfirmModal.value = true
  }).catch(() => {
    uni.hideLoading()
    showConfirmModal.value = true
  })
}

function hideExchangeConfirm() {
  showConfirmModal.value = false
}

function confirmExchange() {
  hideExchangeConfirm()
  
  // 检查用户登录状态
  if (!hasUserSession()) {
    uni.showModal({
      title: '需要登录',
      content: '请先登录后再进行兑换',
      confirmText: '去登录',
      cancelText: '取消',
      success: (res) => {
        if (res.confirm) {
          openAuthPage('login')
        }
      }
    })
    return
  }
  
  // 先检查是否有24小时内的有效订单
  uni.showLoading({
    title: '处理中...',
  })
  checkActiveOrder(productId.value).then((data) => {
    if (data && data.has_active && data.order && data.order.id) {
      // 有有效订单，直接跳转
      activeOrderId.value = Number(data.order.id || 0)
      activeOrderExpiresAt.value = String(data.order.expires_at || '')
      startCountdown()
      uni.hideLoading()
      uni.showToast({
        title: '已为您打开有效订单',
        icon: 'none',
      })
      uni.redirectTo({
        url: '/pages/order/result?id=' + encodeURIComponent(String(data.order.id)),
      })
      return
    }
    // 没有有效订单，正常下单
    submitOrder()
  }).catch(() => {
    // 检查失败也走正常下单
    submitOrder()
  })
}

function submitOrder() {
  createOrder({
    product_id: productId.value,
    quantity: 1,
    buyer_contact: '',
    buyer_email: '',
    remark: '',
  }).then((data) => {
    uni.hideLoading()
    uni.redirectTo({
      url: '/pages/order/result?id=' + encodeURIComponent(String(data.id || 0)),
    })
  }).catch((message) => {
    uni.hideLoading()
    uni.showToast({
      title: String(message || '兑换失败'),
      icon: 'none',
    })
  })
}

function goOrder() {
  uni.navigateTo({
    url: '/pages/order/create?id=' + encodeURIComponent(String(productId.value)),
  })
}

function loadDetail() {
  if (productId.value <= 0) {
    uni.showToast({
      title: '商品参数缺失',
      icon: 'none',
    })
    return
  }
  uni.showLoading({
    title: '加载中',
  })
  resetDetailSwiperState()
  fetchProduct(productId.value).then((data) => {
    detail.id = Number(data.id || 0)
    detail.name = String(data.name || '')
    detail.name_en = String(data.name_en || '')
    detail.exchange_energy = Number(data.exchange_energy || 0)
    detail.description = String(data.description || '')
    detail.game_size = String(data.game_size || '')
    detail.supported_languages = String(data.supported_languages || '')
    detail.compatibility = String(data.compatibility || '')
    detail.cover_image = data && data.cover_image
      ? String(data.cover_image)
      : (data && data.display_image ? String(data.display_image) : '')
    detail.images = data && data.gallery_images ? data.gallery_images : []
    detail.category = data && data.category ? data.category : null
    detail.kindCategory = data && data.kindCategory ? data.kindCategory : null
    detail.resources = data && data.resources ? data.resources : {
      downloads: [],
      tutorials: [],
    }
    detail.recommend_products = data && data.recommend_products ? data.recommend_products : []

    if (!detail.images || detail.images.length == 0) {
      detailSwiperHeight.value = clampSwiperHeight(detailSwiperWidth.value * 0.72)
    }
  }).catch((message) => {
    uni.showToast({
      title: String(message || '商品加载失败'),
      icon: 'none',
    })
  }).finally(() => {
    uni.hideLoading()
  })
}

function parseDateTime(value: string): number {
  const text = String(value || '').trim()
  if (text == '') {
    return 0
  }
  // 兼容 'YYYY-MM-DD HH:mm:ss' 格式（小程序部分平台不识别空格分隔）
  const normalized = text.indexOf('T') >= 0 ? text : text.replace(' ', 'T')
  const stamp = Date.parse(normalized)
  if (isNaN(stamp)) {
    return 0
  }
  return stamp
}

function pad2(value: number): string {
  return value < 10 ? '0' + String(value) : String(value)
}

function updateCountdown() {
  const expireAt = parseDateTime(activeOrderExpiresAt.value)
  if (expireAt <= 0) {
    countdownText.value = '00:00:00'
    return
  }
  const remain = expireAt - Date.now()
  if (remain <= 0) {
    countdownText.value = '00:00:00'
    activeOrderId.value = 0
    activeOrderExpiresAt.value = ''
    stopCountdown()
    return
  }
  const totalSec = Math.floor(remain / 1000)
  const h = Math.floor(totalSec / 3600)
  const m = Math.floor((totalSec % 3600) / 60)
  const s = totalSec % 60
  countdownText.value = pad2(h) + ':' + pad2(m) + ':' + pad2(s)
}

function startCountdown() {
  stopCountdown()
  updateCountdown()
  countdownTimer = setInterval(() => {
    updateCountdown()
  }, 1000)
}

function stopCountdown() {
  if (countdownTimer != null) {
    clearInterval(countdownTimer)
    countdownTimer = null
  }
}

function goToActiveOrder() {
  if (activeOrderId.value <= 0) {
    return
  }
  uni.navigateTo({
    url: '/pages/order/result?id=' + encodeURIComponent(String(activeOrderId.value)),
  })
}

function checkExistingOrder() {
  if (!hasUserSession() || productId.value <= 0) {
    activeOrderId.value = 0
    activeOrderExpiresAt.value = ''
    stopCountdown()
    return
  }
  checkActiveOrder(productId.value).then((data) => {
    if (data && data.has_active && data.order && data.order.id) {
      activeOrderId.value = Number(data.order.id || 0)
      activeOrderExpiresAt.value = String(data.order.expires_at || '')
      startCountdown()
    } else {
      activeOrderId.value = 0
      activeOrderExpiresAt.value = ''
      stopCountdown()
    }
  }).catch(() => {
    activeOrderId.value = 0
    activeOrderExpiresAt.value = ''
    stopCountdown()
  })
}

onLoad((query) => {
  syncThemeChrome()
  productId.value = query && query.id ? Number(query.id) : 0
  loadDetail()
  checkExistingOrder()
})

onShow(() => {
  syncThemeChrome()
  checkExistingOrder()
})

onHide(() => {
  stopCountdown()
})

onUnload(() => {
  stopCountdown()
})
</script>

<style>
