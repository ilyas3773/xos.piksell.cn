<template>
  <view class="choice-page" :class="themeClass">
    <view class="choice-card">
      <text class="choice-title">二维码支付</text>
      <text class="choice-desc">请打开二维码支付页完成付款，付款完成后返回能量页面查询到账状态。</text>

      <view class="pay-option" @click="openQrPay" @tap="openQrPay">
        <view class="option-icon blue"><text class="option-icon-text">码</text></view>
        <view class="option-main">
          <text class="option-title">二维码付款</text>
          <text class="option-desc">打开二维码页面扫码付款，付款后返回这里点击支付查询。</text>
        </view>
        <text class="option-arrow">›</text>
      </view>

      <view class="action-row">
        <view class="plain-button" @click="goBack" @tap="goBack">
          <text class="plain-button-text">返回</text>
        </view>
        <view class="primary-button" @click="queryPayment" @tap="queryPayment">
          <text class="primary-button-text">支付查询</text>
        </view>
      </view>
    </view>
  </view>
</template>

<script setup lang="uts">
import { getThemeMode, syncThemeChrome } from '../../utils/theme.uts'
import { fetchRechargeOrderStatus } from '../../utils/user.uts'

const payUrl = ref('')
const orderNo = ref('')
const checkingPayment = ref(false)

function decodeQueryValue(value: string): string {
  if (value == '') {
    return ''
  }
  return String(decodeURIComponent(value))
}

function openUrlOnH5(url: string): boolean {
  // #ifdef H5
  window.location.href = url
  return true
  // #endif
  // #ifndef H5
  return false
  // #endif
}

function copyPayUrl(url: string, title: string, content: string) {
  if (url == '') {
    uni.showToast({ title: '支付链接不存在', icon: 'none' })
    return
  }
  uni.setClipboardData({
    data: url,
    success: () => {
      uni.showModal({
        title: title,
        content: content,
        showCancel: false,
      })
    },
    fail: () => {
      uni.showToast({ title: '复制失败，请重试', icon: 'none' })
    },
  })
}

function openQrPay() {
  if (payUrl.value == '') {
    uni.showToast({ title: '二维码链接不存在', icon: 'none' })
    return
  }
  if (openUrlOnH5(payUrl.value)) {
    return
  }
  copyPayUrl(payUrl.value, '二维码链接已复制', '请到手机浏览器粘贴打开二维码支付页，完成付款后返回这里点击支付查询。')
}

function queryPayment() {
  if (orderNo.value == '') {
    uni.showToast({ title: '订单号不存在', icon: 'none' })
    return
  }
  if (checkingPayment.value) {
    return
  }
  checkingPayment.value = true
  uni.showLoading({ title: '查询支付...' })
  fetchRechargeOrderStatus(orderNo.value).then((data) => {
    uni.hideLoading()
    const paid = !!(data && data.paid)
    if (paid) {
      uni.removeStorageSync('pending_recharge_order_no')
      uni.removeStorageSync('pending_recharge_pay_url')
      uni.showModal({
        title: '已支付',
        content: '支付成功，能量到账后可返回能量页面查看。',
        showCancel: false,
        success: () => {
          uni.navigateBack()
        },
      })
      return
    }
    uni.showModal({
      title: '你还未付款',
      content: '当前还没有查询到支付成功订单，请先完成付款后再查询。',
      showCancel: false,
    })
  }).catch((message) => {
    uni.hideLoading()
    uni.showToast({ title: String(message || '查询失败，请稍后重试'), icon: 'none' })
  }).finally(() => {
    checkingPayment.value = false
  })
}

function goBack() {
  uni.navigateBack()
}

onLoad((options) => {
  syncThemeChrome()
  const url = options && options['url'] ? String(options['url']) : ''
  const no = options && options['order_no'] ? String(options['order_no']) : ''
  payUrl.value = url != '' ? decodeQueryValue(url) : ''
  orderNo.value = no != '' ? decodeQueryValue(no) : ''
})

onShow(() => {
  syncThemeChrome()
})
</script>

