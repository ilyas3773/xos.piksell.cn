  padding: 34rpx 28rpx;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 48rpx rgba(34, 65, 122, 0.1);
}

.choice-title {
  display: block;
  color: #17233d;
  font-size: 38rpx;
  font-weight: 900;
  text-align: center;
}

.choice-desc {
  display: block;
  margin-top: 16rpx;
  color: #7b8798;
  font-size: 26rpx;
  line-height: 1.55;
  text-align: center;
}

.pay-option {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-top: 28rpx;
  padding: 28rpx 24rpx;
  border: 2rpx solid #edf2f8;
  border-radius: 26rpx;
  background: #fbfdff;
}

.pay-option.disabled {
  opacity: 0.48;
}

.option-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 78rpx;
  height: 78rpx;
  border-radius: 22rpx;
}

.option-icon.blue {
  background: #eaf4ff;
}

.option-icon.green {
  background: #e9fbf2;
}

.option-icon-text {
  color: #1677ff;
  font-size: 28rpx;
  font-weight: 900;
}

.option-icon.green .option-icon-text {
  color: #12a66a;
}

.option-main {
  flex: 1;
  margin-left: 20rpx;
}

.option-title {
  display: block;
  color: #17233d;
  font-size: 30rpx;
  font-weight: 900;
}

.option-desc {
  display: block;
  margin-top: 8rpx;
  color: #8a95a8;
  font-size: 24rpx;
  line-height: 1.45;
}

.option-arrow {
  color: #98a2b3;
  font-size: 48rpx;
  font-weight: 300;
}

.action-row {
  display: flex;
  flex-direction: row;
  gap: 18rpx;
  margin-top: 34rpx;
}

.plain-button,
.primary-button {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  text-align: center;
}

.plain-button {
  background: #f2f5f8;
}

.primary-button {
  background: linear-gradient(135deg, #1677ff 0%, #55b6ff 100%);
}

.plain-button-text,
.primary-button-text {
  font-size: 28rpx;
  font-weight: 800;
}

.plain-button-text {
  color: #475467;
}

.primary-button-text {
  color: #ffffff;
}

.theme-dark { background: #050505; }
</style>
