/* ========== 自定义导航栏（首页同款） ========== */
.page-wrapper {
  width: 100%;
  min-height: 100vh;
}

.custom-navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
  background: linear-gradient(135deg, #ffffff 0%, #f8f9fb 100%);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.navbar-status-bar {
  width: 100%;
}

.navbar-content {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 24rpx;
  height: 88rpx;
}

.navbar-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  flex: 1;
  min-width: 0;
}

.navbar-brand-logo {
  width: 72rpx;
  height: 72rpx;
  flex-shrink: 0;
}

.navbar-logo-image {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: #f0f4ff;
  box-shadow: 0 6rpx 16rpx rgba(22, 119, 255, 0.16);
}

.navbar-logo-fallback {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #1677ff 0%, #69b1ff 100%);
  position: relative;
  overflow: hidden;
  box-shadow: 0 6rpx 16rpx rgba(22, 119, 255, 0.28);
}

.navbar-logo-leaf {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 28rpx;
  height: 28rpx;
  background: #ffffff;
  border-radius: 50%;
}

.navbar-logo-bite {
  position: absolute;
  right: 10rpx;
  bottom: 10rpx;
  width: 16rpx;
  height: 16rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f8f9fb 100%);
  border-radius: 50%;
}

.navbar-brand-info {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  min-width: 0;
}

.navbar-site-name {
  font-size: 30rpx;
  font-weight: 800;
  color: #16213a;
  letter-spacing: 1rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.navbar-site-tagline {
  font-size: 20rpx;
  color: #7d869b;
  letter-spacing: 0.5rpx;
  white-space: nowrap;
}

.navbar-right {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}

.theme-float-button {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f0f4ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(22, 119, 255, 0.14), 0 0 0 3rpx rgba(22, 119, 255, 0.1);
}

.theme-float-icon {
  font-size: 30rpx;
}

/* ========== 深色主题 ========== */
