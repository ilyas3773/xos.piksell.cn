<template>
  <view class="page-wrapper" :class="themeClass()">
    <view class="mine-topbar" @click="toggleTheme">
      <text class="mine-topbar-icon">{{ themeMode == 'dark' ? '☀️' : '🌕' }}</text>
    </view>
    <scroll-view class="page-shell mine-shell" scroll-y="true" :style="scrollViewStyle">
      <view class="page-container mine-page">
        <view class="tech-card user-header" @click="handleUserHeaderClick">
          <view class="user-avatar-wrap">
            <image v-if="avatarUrl() != ''" class="user-avatar-image" :src="avatarUrl()" mode="aspectFill"></image>
            <text v-else class="user-avatar-text">{{ avatarText() }}</text>
          </view>
          <view class="user-info-main">
            <text class="user-name">{{ loggedIn ? (userInfo.nickname || userInfo.username || '发卡小程序') : '点击登录' }}</text>
            <text class="user-account" v-if="loggedIn">登录名：{{ userInfo.username || '-' }}</text>
            <text class="user-edit-tip">{{ loggedIn ? '点击编辑资料' : '点击登录' }}</text>
          </view>
        </view>

        <view class="grid-wrap">
          <view class="grid-row">
            <view class="tech-card grid-card" @click="signInToday">
              <view class="card-icon-wrap blue-icon">
                <text class="card-icon">📅</text>
              </view>
              <text class="card-title">{{ userInfo.today_signed_in ? '今日已签到' : '每日签到' }}</text>
            </view>
            <view class="tech-card grid-card" @click="rechargeEnergy">
              <view class="card-icon-wrap purple-icon">
                <text class="card-icon">👤</text>
              </view>
              <text class="card-title">充值能量</text>
            </view>
          </view>

          <view class="grid-row mixed-row">
            <view class="tech-card energy-big-card">
              <view class="energy-gauge">
                <view class="gauge-bg"></view>
                <view class="gauge-fill"></view>
                <view class="gauge-ticks">
                  <view class="tick" v-for="i in 11" :key="'tick-' + i" :class="'tick-' + i"></view>
                </view>
                <text class="energy-value">{{ userInfo.energy }}</text>
              </view>
              <text class="energy-label">剩余能量: {{ userInfo.energy }}</text>
              <view class="recharge-btn" @click="rechargeEnergy">
                <text class="recharge-btn-text">充值能量</text>
              </view>
            </view>

            <view class="grid-card-col">
              <view class="tech-card grid-card sm-card" @click="openContactCustomer">
                <view class="card-icon-wrap purple-icon">
                  <text class="card-icon">💬</text>
                </view>
                <text class="card-title">联系客服</text>
              </view>
              <view class="tech-card grid-card sm-card" @click="openWishModal">
                <view class="card-icon-wrap purple-icon">
                  <text class="card-icon">✨</text>
                </view>
                <text class="card-title">我要许愿</text>
              </view>
            </view>
          </view>

          <view class="grid-row">
            <view class="tech-card grid-card" @click="openHelp">
              <view class="card-icon-wrap purple-icon">
                <text class="card-icon">🎯</text>
              </view>
              <text class="card-title">帮助</text>
            </view>
            <view class="tech-card grid-card" @click="openAbout">
              <view class="card-icon-wrap blue-icon">
                <text class="card-icon">🛡️</text>
              </view>
              <text class="card-title">关于我们</text>
            </view>
          </view>

          <view class="grid-row">
            <view class="tech-card grid-card" @click="openInvite">
              <view class="card-icon-wrap blue-icon">
                <text class="card-icon">📥</text>
              </view>
              <text class="card-title">邀请好友</text>
            </view>
            <view class="tech-card grid-card" @click="openAllOrders">
              <view class="card-icon-wrap purple-icon">
                <text class="card-icon">📋</text>
              </view>
              <text class="card-title">我的订单</text>
            </view>
          </view>

          <view class="grid-row" v-if="loggedIn">
            <view class="tech-card grid-card full-card" @click="logout">
              <view class="card-icon-wrap purple-icon">
                <text class="card-icon">🚪</text>
              </view>
              <text class="card-title">退出登录</text>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>

    <view class="wish-modal-mask" v-if="contactModalVisible" @click="closeContactCustomer">
      <view class="wish-modal" @click.stop>
        <view class="wish-modal-head">
          <text class="wish-modal-title">📞 联系客服</text>
          <text class="wish-modal-close" @click="closeContactCustomer">✕</text>
        </view>
        <view class="wish-modal-body">
          <text class="wish-modal-tip">在线客服为您解答疑问、处理上架请求</text>

          <view class="contact-list">
            <view class="contact-row" v-if="customerContact.wechat != ''">
              <view class="contact-row-left">
                <text class="contact-icon">💬</text>
                <view class="contact-info">
                  <text class="contact-label">客服微信</text>
                  <text class="contact-value">{{ customerContact.wechat }}</text>
                </view>
              </view>
              <view class="contact-copy-btn" @click="copyContact(customerContact.wechat, '微信号')">
                <text class="contact-copy-text">复制</text>
              </view>
            </view>

            <view class="contact-row" v-if="customerContact.qq != ''">
              <view class="contact-row-left">
                <text class="contact-icon">🐧</text>
                <view class="contact-info">
                  <text class="contact-label">客服 QQ</text>
                  <text class="contact-value">{{ customerContact.qq }}</text>
                </view>
              </view>
              <view class="contact-copy-btn" @click="copyContact(customerContact.qq, 'QQ号')">
                <text class="contact-copy-text">复制</text>
              </view>
            </view>

            <view class="contact-row" v-if="customerContact.phone != ''">
              <view class="contact-row-left">
                <text class="contact-icon">📱</text>
                <view class="contact-info">
                  <text class="contact-label">客服电话</text>
                  <text class="contact-value">{{ customerContact.phone }}</text>
                </view>
              </view>
              <view class="contact-copy-btn" @click="copyContact(customerContact.phone, '电话号')">
                <text class="contact-copy-text">复制</text>
              </view>
            </view>

            <view class="contact-row" v-if="customerContact.email != ''">
              <view class="contact-row-left">
                <text class="contact-icon">📧</text>
                <view class="contact-info">
                  <text class="contact-label">客服邮箱</text>
                  <text class="contact-value">{{ customerContact.email }}</text>
                </view>
              </view>
              <view class="contact-copy-btn" @click="copyContact(customerContact.email, '邮箱')">
                <text class="contact-copy-text">复制</text>
              </view>
            </view>

            <view v-if="customerContact.wechat == '' && customerContact.qq == '' && customerContact.phone == '' && customerContact.email == ''" class="contact-empty">
              <text class="contact-empty-text">暂未配置客服联系方式</text>
            </view>
          </view>

          <text v-if="customerContact.work_time != ''" class="contact-work-time">
            🕐 客服工作时间：{{ customerContact.work_time }}
          </text>
        </view>
        <view class="wish-modal-foot">
          <button class="wish-modal-btn confirm" style="flex:1;" @click="closeContactCustomer">关闭</button>
        </view>
      </view>
    </view>

    <view class="wish-modal-mask" v-if="wishModalVisible" @click="closeWishModal">
      <view class="wish-modal" @click.stop>
        <view class="wish-modal-head">
          <text class="wish-modal-title">✨ 我要许愿</text>
          <text class="wish-modal-close" @click="closeWishModal">✕</text>
        </view>
        <view class="wish-modal-body">
          <text class="wish-modal-tip">告诉我们您想要的游戏 / 应用，我们会尽快上架</text>

          <view class="wish-form-group">
            <text class="wish-form-label">名称 <text class="wish-required">*</text></text>
            <input class="wish-form-input" v-model="wishName" placeholder="请输入想要的游戏 / 应用名称" />
          </view>

          <view class="wish-form-group">
            <text class="wish-form-label">描述 <text class="wish-form-optional">（选填）</text></text>
            <textarea class="wish-form-textarea" v-model="wishDescription" placeholder="可以描述一下您想要的版本、功能等" />
          </view>

          <view class="wish-form-group">
            <text class="wish-form-label">联系方式 <text class="wish-form-optional">（选填）</text></text>
            <input class="wish-form-input" v-model="wishContact" placeholder="留下QQ / 微信等联系方式，我们上架后通知您" />
          </view>
        </view>
        <view class="wish-modal-foot">
          <button class="wish-modal-btn cancel" @click="closeWishModal">取消</button>
          <button class="wish-modal-btn confirm" @click="submitWish">提交许愿</button>
        </view>
      </view>
    </view>

    <view class="profile-modal-mask" v-if="profileEditorVisible" @click="closeProfileEditor">
      <view class="profile-modal" @click.stop>
        <view class="profile-modal-header">
          <text class="profile-modal-title">编辑用户资料</text>
          <text class="profile-modal-close" @click="closeProfileEditor">×</text>
        </view>
        <view class="profile-field">
          <text class="profile-label">登录名称</text>
          <input class="profile-input" v-model="profileForm.username" placeholder="请输入登录名称" placeholder-class="profile-placeholder" />
        </view>
        <view class="profile-field">
          <text class="profile-label">登录密码</text>
          <input class="profile-input" v-model="profileForm.password" password="true" placeholder="••••••" placeholder-class="profile-placeholder" />
        </view>
        <view class="profile-field">
          <text class="profile-label">用户头像</text>
          <view class="profile-avatar-row">
            <image v-if="profileForm.avatar != ''" class="profile-avatar-preview" :src="profileAvatarPreview()" mode="aspectFill"></image>
            <view v-else class="profile-avatar-empty">
              <text class="profile-avatar-empty-text">头像</text>
            </view>
            <view class="profile-avatar-actions">
              <button class="profile-avatar-btn" @click="chooseLocalAvatar">本地上传</button>
              <button class="profile-avatar-btn" open-type="chooseAvatar" @chooseavatar="chooseWechatAvatar">微信头像</button>
            </view>
          </view>
        </view>
        <view class="profile-field">
          <text class="profile-label">手机号</text>
          <input class="profile-input" v-model="profileForm.phone" type="number" placeholder="请输入手机号" placeholder-class="profile-placeholder" />
        </view>
        <view class="profile-actions">
          <button class="profile-btn profile-cancel" @click="closeProfileEditor">取消</button>
          <button class="profile-btn profile-save" @click="submitProfile" :disabled="profileSaving">{{ profileSaving ? '保存中...' : '保存' }}</button>
        </view>
      </view>
    </view>
  </view>
</template>

<script setup lang="uts">
import {
  clearAuth,
  fetchProfile,
  getStoredUser,
  hasUserSession,
  openAuthPage,
  saveUserProfile,
  signInUser,
  updateUserProfile,
  uploadUserAvatar,
} from '../../utils/user.uts'
import {
  openEnergyPage,
  openOrderListPage,
} from '../../utils/navigation.uts'
import {
  resolveAssetUrl,
} from '../../utils/api.uts'
import {
  apiOrigin,
} from '../../utils/shop.uts'

const themeMode = ref('light')

const scrollViewStyle = computed(() => {
  if (themeMode.value == 'dark') {
    return `background: #050505;`
  }
  return ''
})

const loggedIn = ref(false)
const profileEditorVisible = ref(false)
const profileSaving = ref(false)
const wishModalVisible = ref(false)
const contactModalVisible = ref(false)
const wishName = ref('')
const wishDescription = ref('')
const wishContact = ref('')
const customerContact = reactive({
  wechat: '',
  qq: '',
  phone: '',
  email: '',
  qr_image: '',
  work_time: '',
})
const userInfo = reactive({
  id: 0,
  username: '',
  nickname: '',
  phone: '',
  email: '',
  avatar: '',
  energy: 0,
  invite_code: '',
  invite_count: 0,
  today_signed_in: false,
})
const profileForm = reactive({
  username: '',
  password: '',
  nickname: '',
  avatar: '',
  phone: '',
})

function avatarText(): string {
  const name = String(userInfo.nickname || userInfo.username || '')
  if (name == '') {
    return 'U'
  }
  return name.slice(0, 1).toUpperCase()
}

function avatarUrl(): string {
  return resolveAssetUrl(String(userInfo.avatar || ''))
}

function profileAvatarPreview(): string {
  return resolveAssetUrl(String(profileForm.avatar || ''))
}

function applyUser(data: any) {
  userInfo.id = Number(data && data.id ? data.id : 0)
  userInfo.username = String(data && data.username ? data.username : '')
  userInfo.nickname = String(data && data.nickname ? data.nickname : '')
  userInfo.phone = String(data && data.phone ? data.phone : '')
  userInfo.email = String(data && data.email ? data.email : '')
  userInfo.avatar = String(data && data.avatar ? data.avatar : '')
  userInfo.energy = Number(data && data.energy ? data.energy : 0)
  userInfo.invite_code = String(data && data.invite_code ? data.invite_code : '')
  userInfo.invite_count = Number(data && data.invite_count ? data.invite_count : 0)
  userInfo.today_signed_in = !!(data && data.today_signed_in)
  loggedIn.value = userInfo.id > 0
  if (loggedIn.value) {
    saveUserProfile(data)
  }
}

function resetUser() {
  loggedIn.value = false
  userInfo.id = 0
  userInfo.username = ''
  userInfo.nickname = ''
  userInfo.phone = ''
  userInfo.email = ''
  userInfo.avatar = ''
  userInfo.energy = 0
  userInfo.invite_code = ''
  userInfo.invite_count = 0
  userInfo.today_signed_in = false
}

function loadUserCenter() {
  if (!hasUserSession()) {
    resetUser()
    return
  }
  fetchProfile().then((data) => {
    applyUser(data)
  }).catch((message) => {
    const errorText = String(message || '')
    if (errorText.indexOf('401') >= 0 || errorText.indexOf('sign in') >= 0) {
      clearAuth()
      resetUser()
    }
  }).finally(() => {
    uni.stopPullDownRefresh()
  })
}

function signInToday() {
  if (!loggedIn.value) {
    toLogin()
    return
  }
  if (userInfo.today_signed_in) {
    uni.showToast({ title: '今天已经签到过了', icon: 'none' })
    return
  }
  uni.showLoading({ title: '签到中...' })
  signInUser().then((data) => {
    applyUser(data)
    uni.showToast({ title: '签到成功', icon: 'none' })
  }).catch((message) => {
    uni.showToast({ title: String(message || '签到失败'), icon: 'none' })
  }).finally(() => {
    uni.hideLoading()
  })
}

function handleUserHeaderClick() {
  if (!loggedIn.value) {
    toLogin()
    return
  }
  openProfileEditor()
}

function openProfileEditor() {
  profileForm.username = String(userInfo.username || '')
  profileForm.password = ''
  profileForm.nickname = String(userInfo.nickname || '')
  profileForm.avatar = String(userInfo.avatar || '')
  profileForm.phone = String(userInfo.phone || '')
  profileEditorVisible.value = true
}

function closeProfileEditor() {
  if (profileSaving.value) {
    return
  }
  profileEditorVisible.value = false
}

function applyUploadedAvatar(data: any) {
  const profile = data && data.profile ? data.profile : null
  const avatar = data && data.avatar ? data.avatar : null
  if (profile) {
    applyUser(profile)
  }
  if (profile && profile.avatar) {
    profileForm.avatar = String(profile.avatar)
    return
  }
  if (avatar && avatar.url) {
    profileForm.avatar = String(avatar.url)
  }
}

function uploadAvatarFile(filePath: string) {
  if (filePath == '') {
    uni.showToast({ title: '请选择头像图片', icon: 'none' })
    return
  }

  profileSaving.value = true
  uni.showLoading({ title: '上传头像...' })
  uploadUserAvatar(filePath).then((data) => {
    applyUploadedAvatar(data)
    uni.showToast({ title: '头像已上传', icon: 'none' })
  }).catch((message) => {
    uni.showToast({ title: String(message || '头像上传失败'), icon: 'none' })
  }).finally(() => {
    profileSaving.value = false
    uni.hideLoading()
  })
}

function chooseLocalAvatar() {
  uni.chooseImage({
    count: 1,
    sizeType: ['compressed'],
    sourceType: ['album', 'camera'],
    success: (res) => {
      const paths = res.tempFilePaths
      const filePath = paths && paths.length > 0 ? String(paths[0]) : ''
      uploadAvatarFile(filePath)
    },
    fail: (error) => {
      const message = error && error.errMsg ? String(error.errMsg) : '选择头像失败'
      if (message.indexOf('cancel') < 0) {
        uni.showToast({ title: message, icon: 'none' })
      }
    },
  })
}

function chooseWechatAvatar(event: any) {
  const detail = event && event.detail ? event.detail : null
  const filePath = detail && detail.avatarUrl ? String(detail.avatarUrl) : ''
  uploadAvatarFile(filePath)
}

function submitProfile() {
  const username = String(profileForm.username || '').trim()
  const password = String(profileForm.password || '')
  if (username == '') {
    uni.showToast({ title: '请输入登录名称', icon: 'none' })
    return
  }
  if (password != '' && password.length < 6) {
    uni.showToast({ title: '密码至少 6 位', icon: 'none' })
    return
  }

  const payload: any = {
    username: username,
    nickname: String(userInfo.nickname || '').trim(),
    avatar: String(profileForm.avatar || '').trim(),
    phone: String(profileForm.phone || '').trim(),
  }
  if (password != '') {
    payload.password = password
  }

  profileSaving.value = true
  updateUserProfile(payload).then((data) => {
    applyUser(data)
    profileEditorVisible.value = false
    uni.showToast({ title: '保存成功', icon: 'none' })
  }).catch((message) => {
    uni.showToast({ title: String(message || '保存失败'), icon: 'none' })
  }).finally(() => {
    profileSaving.value = false
  })
}

function rechargeEnergy() {
  openEnergyPage()
}

function contactService() {
  openContactCustomer()
}

function openComplaint() {
  openWishModal()
}

function openContactCustomer() {
  contactModalVisible.value = true
  if (customerContact.wechat == '' && customerContact.qq == '' && customerContact.phone == '' && customerContact.email == '') {
    loadCustomerContact()
  }
}

function closeContactCustomer() {
  contactModalVisible.value = false
}

function openWishModal() {
  wishName.value = ''
  wishDescription.value = ''
  wishContact.value = ''
  wishModalVisible.value = true
  if (customerContact.wechat == '' && customerContact.qq == '' && customerContact.phone == '' && customerContact.email == '') {
    loadCustomerContact()
  }
}

function closeWishModal() {
  wishModalVisible.value = false
}

function copyContact(value: string, label: string) {
  const text = String(value || '').trim()
  if (text == '') {
    uni.showToast({ title: '内容为空', icon: 'none' })
    return
  }
  uni.setClipboardData({
    data: text,
    success: () => {
      uni.showToast({ title: label + '已复制', icon: 'none' })
    },
  })
}

function loadCustomerContact() {
  uni.request({
    url: apiOrigin() + '/api/shop/customer-contact',
    method: 'GET',
    success: (res: any) => {
      const body = res && res.data ? res.data : null
      if (body && Number(body.code) === 0 && body.data) {
        const data = body.data
        customerContact.wechat = String(data.wechat || '')
        customerContact.qq = String(data.qq || '')
        customerContact.phone = String(data.phone || '')
        customerContact.email = String(data.email || '')
        customerContact.qr_image = String(data.qr_image || '')
        customerContact.work_time = String(data.work_time || '')
      }
    },
  })
}

function submitWish() {
  const name = String(wishName.value || '').trim()
  if (name == '') {
    uni.showToast({ title: '请填写名称', icon: 'none' })
    return
  }
  uni.showLoading({ title: '提交中...' })
  uni.request({
    url: apiOrigin() + '/api/shop/wishes',
    method: 'POST',
    header: { 'content-type': 'application/x-www-form-urlencoded' },
    data: {
      name: name,
      description: String(wishDescription.value || '').trim(),
      contact: String(wishContact.value || '').trim(),
    },
    success: (res: any) => {
      uni.hideLoading()
      const body = res && res.data ? res.data : null
      if (body && Number(body.code) === 0) {
        uni.showToast({ title: '许愿成功，感谢您的反馈！', icon: 'none' })
        closeWishModal()
      } else {
        uni.showToast({
          title: String(body && body.msg ? body.msg : '提交失败'),
          icon: 'none',
        })
      }
    },
    fail: () => {
      uni.hideLoading()
      uni.showToast({ title: '网络错误，请重试', icon: 'none' })
    },
  })
}

function openHelp() {
  uni.showToast({ title: '帮助中心即将开放', icon: 'none' })
}

function openAbout() {
  uni.showToast({ title: '关于我们', icon: 'none' })
}

function openInvite() {
  if (!loggedIn.value) {
    toLogin()
    return
  }
  if (userInfo.invite_code == '') {
    uni.showToast({ title: '暂无邀请码', icon: 'none' })
    return
  }
  uni.setClipboardData({
    data: userInfo.invite_code,
    success: () => {
      uni.showToast({ title: '邀请码已复制：' + userInfo.invite_code, icon: 'none' })
    },
  })
}

function openAllOrders() {
  if (!loggedIn.value) {
    toLogin()
    return
  }
  openOrderListPage()
}

function toLogin() {
  openAuthPage('login')
}

function logout() {
  uni.showModal({
    title: '提示',
    content: '确定要退出登录吗？',
    confirmText: '退出',
    cancelText: '取消',
    success: (res) => {
      if (res.confirm) {
        clearAuth()
        resetUser()
        uni.showToast({ title: '已退出登录', icon: 'none' })
      }
    },
  })
}

onLoad(() => {
  loadTheme()
  syncChrome()
  if (hasUserSession()) {
    const stored = getStoredUser()
    if (stored) { applyUser(stored) }
    loadUserCenter()
  }
})

const MINE_THEME_KEY = 'mine_ui_theme_mode'

function normalizedThemeMode(value: string): string {
  return String(value || '').trim() == 'dark' ? 'dark' : 'light'
}

function themeClass(): string {
  return themeMode.value == 'dark' ? 'theme-dark' : 'theme-light'
}

function applyTheme(mode: string) {
  themeMode.value = normalizedThemeMode(mode)
  uni.setStorageSync(MINE_THEME_KEY, themeMode.value)
  syncChrome()
}

function loadTheme() {
  const saved = String(uni.getStorageSync(MINE_THEME_KEY) || '')
  themeMode.value = normalizedThemeMode(saved)
}

function syncChrome() {
  if (themeMode.value == 'dark') {
    uni.setNavigationBarColor({ frontColor: '#ffffff', backgroundColor: '#050505' })
    uni.setTabBarStyle({
      color: '#9ca3af',
      selectedColor: '#1677ff',
      backgroundColor: '#000000',
      borderStyle: 'black',
    })
    return
  }
  uni.setNavigationBarColor({ frontColor: '#000000', backgroundColor: '#ffffff' })
  uni.setTabBarStyle({
    color: '#6b7280',
    selectedColor: '#1677ff',
    backgroundColor: '#ffffff',
    borderStyle: 'white',
  })
}

function toggleTheme() {
  applyTheme(themeMode.value == 'dark' ? 'light' : 'dark')
  uni.showToast({
    title: themeMode.value == 'dark' ? '已切换至黑色UI' : '已切换至白色UI',
    icon: 'none',
  })
}

onShow(() => {
  if (hasUserSession()) {
    const stored = getStoredUser()
    if (stored) { applyUser(stored) }
    loadUserCenter()
  } else {
    resetUser()
  }
})

onPullDownRefresh(() => {
  if (hasUserSession()) {
    loadUserCenter()
  } else {
    uni.stopPullDownRefresh()
  }
})
</script>

