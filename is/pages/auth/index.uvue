  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(255, 0, 128, 0.25) 0%, transparent 70%);
  top: -100rpx;
  right: -100rpx;
}

.glow-cyan {
  width: 350rpx;
  height: 350rpx;
  background: radial-gradient(circle, rgba(0, 255, 255, 0.2) 0%, transparent 70%);
  bottom: 50rpx;
