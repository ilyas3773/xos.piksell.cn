<template>
  <scroll-view class="page-shell" scroll-y="true">
    <view class="auth-page">
      <!-- 深色背景 -->
      <view class="bg-dark"></view>
      
      <!-- 霓虹网格 -->
      <view class="neon-grid"></view>
      
      <!-- 霓虹光效 -->
      <view class="neon-glow glow-pink"></view>
      <view class="neon-glow glow-cyan"></view>
      <view class="neon-glow glow-purple"></view>

      <!-- 顶部 Logo -->
      <view class="auth-header">
        <view class="logo-container">
          <text class="logo-text">◈</text>
        </view>
        <text class="brand-name">PIKSELL</text>
        <view class="neon-line"></view>
      </view>

      <!-- 霓虹卡片 -->
      <view class="cyber-card">
        <!-- 扫描线 -->
        <view class="scan-effect"></view>
        
        <!-- 边框发光 -->
        <view class="card-border-left"></view>
        <view class="card-border-right"></view>
        
        <!-- 标签切换 -->
        <view class="mode-tabs">
          <view 
            class="tab-btn" 
            :class="{ active: mode == 'login' }" 
            @click="switchMode('login')"
          >
            <text class="tab-num">01</text>
            <text class="tab-label">登录</text>
            <view class="tab-glow" v-if="mode == 'login'"></view>
          </view>
          <view 
            class="tab-btn" 
            :class="{ active: mode == 'register' }" 
            @click="switchMode('register')"
          >
            <text class="tab-num">02</text>
            <text class="tab-label">注册</text>
            <view class="tab-glow" v-if="mode == 'register'"></view>
          </view>
        </view>

        <!-- 表单 -->
        <view class="form-box">
          <!-- 用户名 -->
          <view class="field-group">
            <view class="field-label">
              <text class="label-icon">▸</text>
              <text class="label-text">用户名</text>
            </view>
            <input 
              class="neon-input" 
              v-model="form.username" 
              placeholder="请输入用户名"
              placeholder-class="ph-color"
            />
          </view>

          <!-- 邮箱 -->
          <view class="field-group" v-if="mode == 'register'">
            <view class="field-label">
              <text class="label-icon">▸</text>
              <text class="label-text">邮箱</text>
            </view>
            <input 
              class="neon-input" 
              v-model="form.email" 
              type="email"
              placeholder="选填，用于找回密码"
              placeholder-class="ph-color"
            />
          </view>

          <!-- 密码 -->
          <view class="field-group">
            <view class="field-label">
              <text class="label-icon">▸</text>
              <text class="label-text">密码</text>
            </view>
            <input 
              class="neon-input" 
              v-model="form.password" 
              password="true" 
              placeholder="请输入密码"
              placeholder-class="ph-color"
            />
          </view>

          <!-- 确认密码 -->
          <view class="field-group" v-if="mode == 'register'">
            <view class="field-label">
              <text class="label-icon">▸</text>
              <text class="label-text">确认密码</text>
            </view>
            <input 
              class="neon-input" 
              v-model="form.confirmPassword" 
              password="true" 
              placeholder="再次输入密码"
              placeholder-class="ph-color"
            />
          </view>
        </view>

        <!-- 提交按钮 -->
        <view class="btn-area">
          <view class="btn-glow-bg"></view>
          <button class="cyber-btn" @click="submitAuth" :disabled="submitting">
            <text class="btn-content">{{ submitting ? '处理中...' : (mode == 'login' ? '登录' : '注册') }} ▶</text>
          </button>
        </view>

        <!-- 分割 -->
        <view class="divider-box">
          <view class="divider-line"></view>
          <text class="divider-text">或</text>
          <view class="divider-line"></view>
        </view>

        <!-- 微信登录 -->
        <button class="neon-btn-wx" @click="wxLogin" v-if="canUseWxLogin()">
          <text class="wx-content">▼ 微信登录</text>
        </button>

        <!-- 切换 -->
        <view class="link-area">
          <text class="link-hint">{{ mode == 'login' ? '没有账号?' : '已有账号?' }}</text>
          <text class="link-action" @click="switchMode(mode == 'login' ? 'register' : 'login')">
            {{ mode == 'login' ? '立即注册' : '立即登录' }}
          </text>
        </view>
      </view>

      <!-- 底部 -->
      <view class="cyber-footer">
        <text class="footer-tips">登录即表示您同意我们的</text>
        <view class="footer-links">
          <text class="footer-link" @click="goTerms">服务条款</text>
          <text class="footer-sep">&</text>
          <text class="footer-link" @click="goPrivacy">隐私政策</text>
        </view>
      </view>
    </view>
  </scroll-view>
</template>

<script setup lang="uts">
import {
  loginUser,
  registerUser,
} from '../../utils/user.uts'
import {
  wxLogin as performWxLogin,
} from '../../utils/wx-auth.uts'

const mode = ref('login')
const submitting = ref(false)
const form = reactive({
  username: '',
  email: '',
  password: '',
  confirmPassword: '',
})

function switchMode(nextMode: string) {
  mode.value = nextMode == 'register' ? 'register' : 'login'
}

function canUseWxLogin(): boolean {
  // #ifdef MP-WEIXIN
  return true
  // #endif
  // #ifndef MP-WEIXIN
  return false
  // #endif
}

function validateForm(): string {
  if (form.username == '') return '请输入用户名'
  if (form.username.length < 3) return '用户名至少3个字符'
  if (form.password.length < 6) return '密码至少6个字符'
  if (mode.value == 'register' && form.confirmPassword != form.password) {
    return '两次输入的密码不一致'
  }
  return ''
}

function buildSubmitData(): any {
  if (mode.value == 'login') {
    return { username: form.username, password: form.password }
  }
  return {
    username: form.username,
    nickname: form.username,
    email: form.email,
    password: form.password,
  }
}

function submitAuth() {
  if (submitting.value) return
  
  const err = validateForm()
  if (err != '') {
    uni.showToast({ title: err, icon: 'none' })
    return
  }

  submitting.value = true
  uni.showLoading({ title: mode.value == 'login' ? '登录中...' : '注册中...' })

  const action = mode.value == 'login' ? loginUser(buildSubmitData()) : registerUser(buildSubmitData())
  
  action.then(() => {
    uni.showToast({ title: mode.value == 'login' ? '登录成功' : '注册成功', icon: 'none' })
    setTimeout(() => uni.navigateBack(), 500)
  }).catch((msg) => {
    uni.showToast({ title: String(msg || '操作失败'), icon: 'none' })
  }).finally(() => {
    submitting.value = false
    uni.hideLoading()
  })
}

function wxLogin() {
  if (submitting.value) return

  submitting.value = true
  uni.showLoading({ title: '微信登录中...' })

  performWxLogin().then(() => {
    uni.showToast({ title: '登录成功', icon: 'none' })
    setTimeout(() => uni.navigateBack(), 500)
  }).catch((msg) => {
    uni.showToast({ title: String(msg || '微信登录失败'), icon: 'none' })
  }).finally(() => {
    submitting.value = false
    uni.hideLoading()
  })
}

function goTerms() {
  uni.navigateTo({ url: '/pages/faq/index?type=terms' })
}

function goPrivacy() {
  uni.navigateTo({ url: '/pages/faq/index?type=privacy' })
}

onLoad((query) => {
  switchMode(query && query.mode ? String(query.mode) : 'login')
})
</script>

<style>
