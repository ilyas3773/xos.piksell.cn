  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: 
    linear-gradient(rgba(0, 245, 255, 0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0, 245, 255, 0.03) 1px, transparent 1px);
  background-size: 80rpx 80rpx;
  z-index: -1;
}

/* ========== 霓虹光效 ========== */
.neon-glow {
  position: fixed;
  border-radius: 50%;
  filter: blur(120rpx);
  z-index: -1;
}

